# ============================================================
# API ディレクトリ セキュリティ設定
# ============================================================
# 役割: threads_api.php への直接アクセスを防止する（関数ライブラリのため）
# ============================================================

# threads_api.php は他のファイルからrequireされる関数ライブラリ
# 直接アクセスを禁止
<Files "threads_api.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</Files>
