<?php

// ===============================================================
// ThreadsStyle CONFIGURATION EXAMPLE（配布用ツール側）
// ===============================================================
// このファイルは設定ファイルの雛形です。
// ファイル名を 'config.php' にリネームし、以下の値をあなたの環境に合わせて設定してください。
// ===============================================================

// --- APIシークレットトークン ---
// クライアント(ツール)と認証サーバー(verify.php)間の通信を保護するための秘密のトークン
// ★ LP/admin/config.php と同じ値を設定すること
define('SECRET_TOKEN', 'YOUR_SUPER_SECRET_TOKEN');

// --- ライセンス認証サーバーのURL (クライアント用) ---
// ツールがライセンス認証のためにアクセスする認証サーバー(verify.php)のURL
// 例: https://your-domain.com/tools/threadsstyle/LP/api/verify.php
define('AUTH_SERVER_URL', 'https://your-domain.com/path/to/LP/api/verify.php');

// --- ツール更新設定 ---
// ツールのバージョン (アップデートチェック時に使用、init.phpで定義されていない場合のフォールバック)
if (!defined('TOOL_VERSION')) {
    define('TOOL_VERSION', 'v1.0.0');
}

// 更新を確認するGitHubリポジトリ (owner/repo)
define('GITHUB_REPO', 'your-github-user/your-repo-name');

// --- Threads API 設定 ---
// Meta Developer Portal で取得した Threads App の情報
// ※ アクセストークンとユーザーIDは管理画面の設定ページからも登録できます
define('THREADS_APP_ID', '');
define('THREADS_APP_SECRET', '');

// --- Gemini API 設定 ---
// Google AI Studio (https://aistudio.google.com/) で取得
define('GEMINI_API_KEY', '');
define('GEMINI_MODEL', 'gemini-3.1-flash-lite-preview'); // gemini-3.1-flash-lite-preview / gemini-3-flash-preview / gemini-2.5-flash-lite-preview-06-17

?>
