# ============================================================
# .gitignore（配布用ツール側）
# ============================================================
# 役割: 配布用ツールの機密ファイルをGitリポジトリから除外する。
# ============================================================

# OS/システムファイル
.DS_Store
Thumbs.db

# --- 機密ファイル ---
admin/config.php
admin/database.sqlite
admin/*.log

# --- 一時ファイル ---
admin/_tmp_update_*
