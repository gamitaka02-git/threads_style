# ============================================================
# .gitignore（プロジェクト全体）
# ============================================================

# --- OS/システムファイル ---
.DS_Store
**/.DS_Store
Thumbs.db
desktop.ini
cookies.txt

# --- IDE/エディタ設定 ---
.vscode/
.idea/
*.swp
*.bak
*~

# --- 環境変数・機密情報 ---
.env
.env.*
**/admin/config.php
**/admin/*.sqlite*

# --- 依存関係・パッケージ管理 ---
node_modules/
**/node_modules/
vendor/
**/vendor/

# --- ログ・一時ファイル ---
*.log
**/admin/*.log
**/admin/_tmp_update_*

# --- 販売・管理側 (LP) ---
LP/admin/stripe-php/
LP/api/webhook.php

# --- システム/ドキュメント（GitHubに公開しないフォルダ） ---
docs/
threads_style/